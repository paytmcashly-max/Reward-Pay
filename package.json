{
  "name": "reward-wallet-platform",
  "private": true,
  "version": "0.1.0",
  "main": "apps/mobile/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace @reward-wallet/api",
    "dev:mobile": "npm run dev --workspace @reward-wallet/mobile",
    "dev:admin": "npm run dev --workspace @reward-wallet/admin",
    "build:mobile": "npm run export:android --workspace @reward-wallet/mobile",
    "build:admin": "npm run build --workspace @reward-wallet/admin",
    "test:api": "npm run test --workspace @reward-wallet/api",
    "doctor:api": "npm run doctor --workspace @reward-wallet/api"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "expo-router": "~6.0.23",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  }
}
