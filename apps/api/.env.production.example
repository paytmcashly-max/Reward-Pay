NODE_ENV=production
PORT=10000
JWT_SECRET=replace-with-strong-production-secret
JWT_TTL_SECONDS=604800
ALLOW_DEV_HEADERS=false
ALLOW_MEMORY_INFRASTRUCTURE=false
EXPLICIT_MOCK_PAYMENTS=false
EXPLICIT_MOCK_PAYOUTS=true
ENABLE_INVITE_LOGIN=true
INVITE_CODE=

DATABASE_URL=postgresql://postgres:password@db.your-supabase-project.supabase.co:5432/postgres?sslmode=require
REDIS_URL=redis://default:password@host:6379
OTP_STATE_FILE_PATH=/tmp/reward-wallet-otp-state.json

CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_PAYMENT_API_VERSION=2025-01-01
CASHFREE_PAYOUT_API_VERSION=2024-01-01
CASHFREE_BASE_URL=https://sandbox.cashfree.com
CASHFREE_WEBHOOK_SECRET=

ADMIN_SUPER_PHONE=
ADMIN_SUPER_PASSWORD=
ADMIN_OPERATOR_PHONE=
ADMIN_OPERATOR_PASSWORD=
