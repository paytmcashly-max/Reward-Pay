{
  "expo": {
    "name": "Reward Wallet",
    "slug": "reward-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "scheme": "reward-wallet",
    "android": {
      "package": "com.rewardwallet.app",
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
